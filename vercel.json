{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "devCommand": "npm run dev",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(self), geolocation=()"
        }
      ]
    }
  ],
  "env": {
    "VITE_APP_ENV": "production",
    "VITE_BETA_MODE": "true",
    "VITE_INVITE_ONLY": "true",
    "VITE_PUBLIC_SIGNUPS": "false",
    "VITE_FEATURE_PIPELINE_V2": "true",
    "VITE_FEATURE_APPROVALS": "true",
    "VITE_FEATURE_COMMAND_CENTER": "true",
    "VITE_FEATURE_PLANNING_COPILOT": "true",
    "VITE_FEATURE_BILLING": "false",
    "VITE_FEATURE_SUBSCRIPTIONS": "false",
    "VITE_FEATURE_OWNERSHIP": "false",
    "VITE_POSTHOG_KEY": "phc_wjiQuLpqaAL8HgG9257Bthy19EbaTQd2wuAAVADIaXZ",
    "VITE_POSTHOG_HOST": "https://app.posthog.com",
    "VITE_SENTRY_DSN": "https://1592351761f161a9b64eb4cc9dbb4a1a@o4511025851531264.ingest.us.sentry.io/4511025950949376"
  }
}